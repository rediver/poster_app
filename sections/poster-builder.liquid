{% comment %}
  Poster Builder section
  Mounts the compiled React app bundle built via `npm run build:theme`.
  Expects assets/poster-builder.js and assets/style.css to exist.
  Optionally select a product to expose its variant map to the app for add-to-cart.
{% endcomment %}

<div id="poster-builder-root"></div>

{%- if section.settings.product and all_products[section.settings.product] -%}
  {%- assign product = all_products[section.settings.product] -%}
  <script id="poster-builder-variants" type="application/json">
    {
      "productId": {{ product.id }},
      "handle": {{ product.handle | json }},
      "options": {{ product.options | json }},
      "variants": [
        {%- for v in product.variants -%}
          {
            "id": {{ v.id }},
            "title": {{ v.title | json }},
            "option1": {{ v.option1 | json }},
            "option2": {{ v.option2 | json }},
            "option3": {{ v.option3 | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

{{ 'style.css' | asset_url | stylesheet_tag }}
{{ 'poster-builder.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Poster builder",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Poster product"
    }
  ]
}
{% endschema %}
